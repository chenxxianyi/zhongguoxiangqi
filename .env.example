# ═══════════════════════════════════════════
# 棋境 (Xiangqi Lab) — 环境变量参考
# ═══════════════════════════════════════════
#
# 复制此文件为 .env 并按你的环境修改：
#   cp .env.example .env
#
# 所有 XIANGQI_* 和 DATABASE_* 变量都会被自动加载。

# ── 服务端口 ──
XIANGQI_HTTP_ADDR=:8080
XIANGQI_WORKER_ADDR=:8081
XIANGQI_SHUTDOWN_TIMEOUT=10s
XIANGQI_ENGINE_MOVE_TIME=600ms
XIANGQI_MAX_UPLOAD_BYTES=2097152
XIANGQI_ALLOWED_ORIGIN=http://localhost:5666

# ── 数据模式 ──
#   memory - 内存存储（默认，无需数据库）
#   mysql  - MySQL 持久化
XIANGQI_DATA_MODE=memory

# ── MySQL 数据库配置（XIANGQI_DATA_MODE=mysql 时需要） ──
DATABASE_HOST=127.0.0.1
DATABASE_PORT=3306
DATABASE_NAME=xiangqi
DATABASE_USER=xiangqi
DATABASE_PASSWORD=change-me
DATABASE_CHARSET=utf8mb4
DATABASE_LOC=UTC
DATABASE_MAX_OPEN_CONNS=20
DATABASE_MAX_IDLE_CONNS=10
DATABASE_CONN_MAX_LIFETIME=30m
# 设为 true 时，程序启动会自动创建数据库（首次启动需要）
DATABASE_AUTO_CREATE=false

# ── Docker Compose 变量（仅用于容器化部署） ──
# MYSQL_DATABASE=xiangqi
# MYSQL_USER=xiangqi
# MYSQL_PASSWORD=change-me
# MYSQL_ROOT_PASSWORD=change-root-me
# MYSQL_DSN=xiangqi:change-me@tcp(mysql:3306)/xiangqi?parseTime=true&charset=utf8mb4
# REDIS_ADDR=redis:6379

# ── 可选：外部引擎 (Pikafish UCI) ──
# XIANGQI_EXTERNAL_ENGINE_ENABLED=false
# XIANGQI_EXTERNAL_ENGINE_PATH=
